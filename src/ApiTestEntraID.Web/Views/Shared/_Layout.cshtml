<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ApiTestEntraID Demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Login" asp-action="Index">Demo App</a>
            <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                <a class="nav-link" asp-controller="Documentation" asp-action="Index">Documentation</a>
                <a class="nav-link" asp-controller="HumanResources" asp-action="Index">HR</a>
                <a class="nav-link" asp-controller="IT" asp-action="Index">IT</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text text-light small me-lg-1">@User.Identity?.Name</span>
                    <a class="nav-link" asp-controller="Login" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="nav-link" asp-controller="Login" asp-action="Index">Login</a>
                }
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>