@model ReportStatsDto
@{
    ViewData["Title"] = "IT Report";
}

<h2>IT Report</h2>

<dl class="row">
    <dt class="col-sm-3">Total tasks</dt>
    <dd class="col-sm-9">@Model.TotalTasks</dd>
    <dt class="col-sm-3">Open tasks</dt>
    <dd class="col-sm-9">@Model.OpenTasks</dd>
    <dt class="col-sm-3">Closed tasks</dt>
    <dd class="col-sm-9">@Model.ClosedTasks</dd>
</dl>

<p>
    <a class="btn btn-secondary" asp-action="Index">Back to IT home</a>
</p>
