@model List<WorkTask>
@{
    var users = ViewBag.Users as List<AppUser> ?? new List<AppUser>();
}

<h2>Documentation Tasks</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Date</th>
            <th>Description</th>
            <th>DepartmentId</th>
            <th>AssignedUserId</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Id</td>
                <td>@t.Date.ToString("yyyy-MM-dd")</td>
                <td>@t.Description</td>
                <td>@t.DepartmentId</td>
                <td>@t.AssignedUserId</td>
            </tr>
        }
    </tbody>
</table>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title">Add Task (Simulation)</h5>
        <form method="post" asp-action="Tasks">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Date</label>
                <input class="form-control" type="date" name="Date" />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <input class="form-control" type="text" name="Description" />
            </div>
            <div class="mb-3">
                <label class="form-label">Assigned User</label>
                <select class="form-select" name="AssignedUserId">
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.FullName (@user.Email)</option>
                    }
                </select>
            </div>
            <button class="btn btn-success" type="submit">Add Task</button>
        </form>
    </div>
</div>